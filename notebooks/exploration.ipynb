  {
   "cell_type": "markdown",
   "id": "ccab4d20",
   "metadata": {},
   "source": [
    "## Question analytique\n",
    "\n",
    "# Comment évolue le volume d'événements médiatiques au Bénin tout au long de 2025 ?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "45f916ab",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Récupère le nombre total d'événements par mois depuis la table events_clean\n",
    "query_volume_evenements = f\"\"\"\n",
    "SELECT\n",
    "    MonthYear AS year_month,\n",
    "    COUNT(*) AS volume_events\n",
    "FROM `{PROJECT_ID}.{DATASET_ID}.events_clean`\n",
    "WHERE MonthYear IS NOT NULL\n",
    "GROUP BY year_month\n",
    "ORDER BY year_month\n",
    "\"\"\"\n",
    "# Exécute la requête SQL et charge les résultats dans un DataFrame pandas\n",
    "df_events_volume = charger_donnees(query_volume_evenements).copy()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "5270b979",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Convertit la colonne mensuelle au format date puis trie les données chronologiquement\n",
    "df_events_volume[\"year_month\"] = pd.to_datetime(\n",
    "    df_events_volume[\"year_month\"].astype(str),\n",
    "    format=\"%Y%m\"\n",
    ")\n",
    "df_events_volume = df_events_volume.sort_values(\"year_month\").reset_index(drop=True)\n",
    "df_events_volume[\"label_month\"] = df_events_volume[\"year_month\"].dt.strftime(\"%b %Y\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "cf50b4a2",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Identifie le mois le plus actif, le mois le plus calme et la moyenne mensuelle\n",
    "idx_max = df_events_volume[\"volume_events\"].idxmax()\n",
    "idx_min = df_events_volume[\"volume_events\"].idxmin()\n",
    "\n",
    "mois_max = df_events_volume.loc[idx_max, \"label_month\"]\n",
    "val_max  = int(df_events_volume.loc[idx_max, \"volume_events\"])\n",
    "\n",
    "mois_min = df_events_volume.loc[idx_min, \"label_month\"]\n",
    "val_min  = int(df_events_volume.loc[idx_min, \"volume_events\"])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "7e8e057a",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Crée une courbe temporelle pour visualiser l'évolution mensuelle du volume d'événements\n",
    "fig_events = px.line(\n",
    "    df_events_volume,\n",
    "    x=\"year_month\",\n",
    "    y=\"volume_events\",\n",
    "    markers=True,\n",
    "    title=\"Évolution mensuelle du volume d'événements sur le Bénin\"\n",
    ")"
   ]
  },
